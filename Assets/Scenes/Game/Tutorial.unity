--- !u!114 &1894791764
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1894791759}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 818bfb4a989768b44a1626be1136fb3d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  dialogueText: {fileID: 559434530}
  audioSource: {fileID: 1894791765}
  typeSound: {fileID: 8300000, guid: b95a6e681a6a3b44dba8e702ed03aca6, type: 3}
  startDelay: 1
  typingSpeed: 0.1
  pitchRange: 0.02
  dialogueEntries:
  - sentence: "\uC624\uB79C\uB9CC\uC774\uB124\uC694.\n\uC815\uB9D0 \uAE34 \uC2DC\uAC04\uC774\uC5C8\uC5B4\uC694."
    duration: 2
  - sentence: "\uADF8 \uC0AC\uC774\uC5D0 \uB9CE\uC774 \uCEF8\uAD70\uC694."
    duration: 2
  - sentence: "\uC870\uC791\uBC95\uC740 \uC870\uAE08\n\uC78A\uC73C\uC168\uC744\uC9C0\uB3C4
      \uBAA8\uB974\uACA0\uB124\uC694."
    duration: 2
  - sentence: "\uAD1C\uCC2E\uC544\uC694.\n\uC774\uBBF8 \uC775\uC219\uD588\uB358 \uAC83\uB4E4\uC774\uC5D0\uC694."
    duration: 2
  - sentence: "{LH}\uC640 {RH}\uB97C \uB20C\uB7EC\uC11C\n\uC591 \uC190\uC744 \uCEE8\uD2B8\uB864\uD574\uBD10\uC694.\n\uC548
      \uBBF8\uB044\uB7EC\uC9C0\uAC8C."
    duration: 6
  - sentence: "{JOY} \uC78A\uC9C0 \uC54A\uC73C\uC168\uC8E0?\n\uCC9C\uCC9C\uD788 \uD314\uC744
      \uC6C0\uC9C1\uC5EC \uBD10\uC694.\n"
    duration: 6
  - sentence: "{LF}\uC640 {RF}\uB85C\uB3C4 \uD55C \uBC1C\uC529\uB9CC\n\uB5BC\uBD10\uC694.
      \uCC9C\uCC9C\uD788."
    duration: 6
  - sentence: "\uBCF4\uC138\uC694.\n\uAE08\uBC29 \uB5A0\uC62C\uB9AC\uC168\uC796\uC544\uC694."
    duration: 3
  - sentence: "\uB9CC\uC57D \uC190\uBC1C\uC774 \uB108\uBB34 \uBB34\uAC81\uB2E4\uBA74\n\uC774\uD6C4
      <color=#50FF50>[ \uAC10\uB3C4\uC124\uC815 ]</color> \uC5D0\uC11C\n\uC870\uC808\uD560
      \uC218 \uC788\uC5B4\uC694. "
    duration: 3
  - sentence: "\uC790, \uC774\uC81C \uD654\uBA74 \uC18D\uC73C\uB85C\n\uB4E4\uC5B4\uC640
      \uC8FC\uC138\uC694."
    duration: 100
  keyHighlightColor: '#50FF50'
  isGamepadMode: 0
